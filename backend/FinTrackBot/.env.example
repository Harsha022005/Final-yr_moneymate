# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here

# Database Configuration
MONGO_URI=mongodb://localhost:27017/Moneymate

# Server Configuration
PORT=5000
ALLOWED_ORIGINS=http://localhost:3000,https://your-production-url.com

# Deployment URLs
WEBHOOK_URL=https://your-ngrok-or-production-url.com/bot
DASHBOARD_URL=https://your-production-dashboard-url.com/

# Security
JWT_SECRET=your_secure_random_secret_here
